{
  "name": "torque",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "cursor:continue": "node scripts/cursor-worker-continue.cjs",
    "cursor:auto-once": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/continue-once.ps1",
    "cursor:auto-loop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cursor-auto-continue-loop.ps1 -IntervalSeconds 120 -MaxRounds 10",
    "dev": "ng serve",
    "build": "ng build",
    "inject-eruda": "node randdev/scripts/inject-eruda.cjs",
    "verify:prod-readiness": "node scripts/verify-production-readiness.mjs",
    "plan:prompt": "node scripts/subagent-prompt.mjs",
    "plan:tasks": "node scripts/subagent-prompt.mjs --list-tasks --plan docs/plans/2026-03-21-production-readiness-paid-plus-l2.md",
    "preview": "ng serve --configuration=production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@angular/animations": "^19.2.20",
    "@angular/common": "^19.1.5",
    "@angular/compiler": "^19.1.5",
    "@angular/core": "^19.1.5",
    "@angular/forms": "^19.1.5",
    "@angular/platform-browser": "^19.1.5",
    "@angular/router": "^19.1.5",
    "@google/genai": "latest",
    "@supabase/supabase-js": "^2.49.1",
    "cheerio": "^1.2.0",
    "cookie": "^0.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "http-proxy-middleware": "^2.0.6",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "openai": "^6.29.0",
    "p-limit": "^7.3.0",
    "pg": "^8.18.0",
    "rxjs": "^7.8.1",
    "stripe": "^20.3.1",
    "swagger-ui-express": "^5.0.1",
    "three": "0.160.0",
    "turndown": "^7.2.2",
    "winston": "^3.11.0",
    "yamljs": "^0.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@angular/build": "^19.1.5",
    "@angular/cli": "^19.1.5",
    "@angular/compiler-cli": "^19.1.5",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.22",
    "happy-dom": "^20.6.2",
    "lucide-angular": "^0.477.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": "^22.0.0"
  }
}
