# Environment Configuration
# Copy this file to .env and fill in your credentials

LIBRARY_BARCODE=247777625491...
EBSCO_USER=pl7321r
EBSCO_PASSWORD=PL?7321R
MOTOR_API_BASE=https://sites.motor.com/m1
PROXY_PORT=3001
# Optional: base URL for `scripts/verify-evidence-links-one-article.js` (default: https://vehapiproxi.vercel.app)
# PROXY_URL=http://localhost:3000
# Optional: default shard for that script (default MOTOR). Script auto-probes other shards if article response is M1 SPA shell.
# CONTENT_SOURCE=GeneralMotors

# Leave unset or use development for local proxy. Do NOT copy NODE_ENV=production from prod —
# it disables SKIP_ARTICLE_ACCESS_AUTH (article routes stay locked).
# NODE_ENV=development

# LOCAL ONLY: with NODE_ENV not production — skip JWT + unlock on article HTML routes for
# `npm run verify:evidence-links -- --local`. Never enable on Vercel.
# SKIP_ARTICLE_ACCESS_AUTH=true

# NVIDIA Nemotron (all AI: parsing, rewrite, tutorials, common-issues)
# Get key from https://build.nvidia.com/ — API key for NVIDIA NIM / integrate.api.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
# Optional: explicit OpenAI base URL (default https://integrate.api.nvidia.com/v1). Overrides LLM_URL-derived base.
# NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1
# Optional: text model override (default nvidia/nemotron-3-super-120b-a12b)
# NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b
# Aliases (e.g. selfdevai .env): LLM_API_KEY, LLM_MODEL, LLM_URL
# LLM_URL is normalized: .../v1/chat/completions -> base .../v1 for the OpenAI SDK
# LLM_URL=https://integrate.api.nvidia.com/v1/chat/completions
# LLM_API_KEY=your_nvidia_api_key_here
# LLM_MODEL=nvidia/nemotron-3-super-120b-a12b
# Vision / multimodal (nemotron_multimodal.js). Confirm model id on build.nvidia.com.
# NEMOTRON_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl
# Optional: set true to use Nemotron vision on PDFs when native extraction returns sparse text.
# ENABLE_NEMOTRON_PDF_VISION_FALLBACK=true
# Optional: min chars before we consider native PDF extraction "good enough" (default 120).
# MIN_NATIVE_PDF_TEXT_LENGTH=120
# Optional: 0-based page index for vision fallback (default 0 = first page).
# PDF_VISION_FALLBACK_PAGE=0

# Supabase (For Background DB Caching)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# `articles` upserts: default minimal columns (no description/code/…). If DB matches
# supabase_schema.sql public.articles, set:
# ARTICLES_UPSERT_EXTENDED=true

# Direct Postgres for schema migrations (run-migrate-schema.js). Use one of:
# - SUPABASE_DB_URL = full URI from Dashboard → Database → Connection string (use "Direct" to avoid pooler errors)
# - SUPABASE_DB_PASSWORD = database password (script builds URL from SUPABASE_URL + this)
# SUPABASE_DB_PASSWORD=your_database_password

# Concurrency for structured Nemotron calls (parse, tutorials, common-issues). Default 3 — reduces 429s.
# NEMOTRON_STRUCTURED_CONCURRENCY=3

# Article content GET rate limit (per IP; behind Vercel use trust proxy). Verify script uses x-vehapi-verify — not limited.
# ARTICLE_RATE_LIMIT_WINDOW_MS=60000
# ARTICLE_RATE_LIMIT_MAX=120

# L2 RAG — optional; after migrate:l2-content-chunk (vector(1024)). Reuses NVIDIA API key.
# ENABLE_L2_EMBEDDINGS=true
# EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
# L2_EMBEDDING_DIMS=1024
# Optional: separate base URL for embeddings (defaults to NEMOTRON_BASE_URL / integrate.api.nvidia.com/v1)
# EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1
# L2_CHUNK_MAX_CHARS=1800
# L2_CHUNK_OVERLAP=120
# L2_EMBED_BATCH_SIZE=16

# Stripe (Payments / Credits)
STRIPE_SANDBOX_SKEY=your_stripe_test_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
