# Environment Configuration
# Copy this file to .env and fill in your credentials

LIBRARY_BARCODE=247777625491...
# EBSCO login (required for Motor proxy session via auth.js authenticate())
EBSCO_USER=
EBSCO_PASSWORD=
# Optional (defaults shown)
# EBSCO_PROFILE=autorepso
# EBSCO_GROUP_ID=remote
MOTOR_API_BASE=https://sites.motor.com/m1
PROXY_PORT=3001
# YMME metadata cache: serve DB immediately; refresh from Motor in background when row is older than N days (default 90).
# METADATA_STALENESS_DAYS=90

# Motor DaaS Fluids/Parts keys (api.motor.com) — HMAC Shared Key auth.
# Covers Fluids, Parts, and YMME vehicle loading. NOT the sites.motor.com proxy session.
# Auth: Scheme=Shared&ApiKey=${PK}&Xdate=${ts}&Sig=HMAC-SHA256("${PK}\nGET\n${ts}\n${path}", SK)
# MOTOR_FLUIDS_PUBLIC_KEY=
# MOTOR_FLUIDS_PRIVATE_KEY=

# Motor DaaS sandbox — limited test dataset, same HMAC auth scheme.
# MOTOR_SANDBOX_PUBLIC_KEY=
# MOTOR_SANDBOX_PRIVATE_KEY=

# Legacy plain-key DaaS auth (older contracts). Prefer MOTOR_FLUIDS_* keys above.
# MOTOR_INFORMATION_PUBLIC_KEY=
# MOTOR_INFORMATION_PRIVATE_KEY=
# MOTOR_INFORMATION_BASE_URL=https://api.motor.com
# MOTOR_INFORMATION_CULTURE=en-US

# Browser CORS (credentialed): defaults include vehapi/vehapiproxi .vercel.app. On Vercel (`VERCEL=1`),
# localhost is NOT allowed — use preview URLs or CORS_ALLOWED_ORIGINS. Locally (no VERCEL, NODE_ENV not production),
# http://localhost:3000 and http://127.0.0.1:3000 are added. `VERCEL_URL` adds https://$VERCEL_URL per deploy.
# For split SPA/API previews or custom domains, add:
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.example.com
# Optional: base URL for `scripts/verify-evidence-links-one-article.js` (default: https://vehapiproxi.vercel.app)
# PROXY_URL=http://localhost:3000
# Optional: default shard for that script (default MOTOR). Script auto-probes other shards if article response is M1 SPA shell.
# CONTENT_SOURCE=GeneralMotors

# Leave unset or use development for local proxy. Do NOT copy NODE_ENV=production from prod —
# it disables SKIP_ARTICLE_ACCESS_AUTH (article routes stay locked).
# NODE_ENV=development

# LOCAL ONLY: with NODE_ENV not production — skip JWT + unlock on article HTML routes for
# `npm run verify:evidence-links -- --local`. Never enable on Vercel.
# SKIP_ARTICLE_ACCESS_AUTH=true

# Vertex AI — all AI: parsing, rewrite, tutorials, vision, embeddings
# Requires: Vertex AI API enabled; service account with Vertex AI User role.
# On Cloud Run, Application Default Credentials (ADC) are used automatically.
# For local dev: run `gcloud auth application-default login` or set GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Optional: GCP region (default us-central1)
# VERTEX_LOCATION=us-central1

# Structured parse model — Gemini 2.5 Flash Lite with native JSON schema mode.
# Used for all data extraction (procedures, DTCs, TSBs, specs).
# VERTEX_PARSE_MODEL=gemini-2.5-flash-lite

# Free-text / tutorial generation model. Can be upgraded to gemini-2.5-flash for richer tutorials.
# VERTEX_TEXT_MODEL=gemini-2.5-flash-lite

# Vision model for image OCR (defaults to same as text model)
# VERTEX_VISION_MODEL=gemini-2.5-flash-lite

# Optional: set true to use Gemini vision on PDFs when Document AI is off and native extraction is sparse.
# ENABLE_NEMOTRON_PDF_VISION_FALLBACK=true
# Optional: min chars before native PDF extraction is considered sufficient (default 120).
# MIN_NATIVE_PDF_TEXT_LENGTH=120
# Optional: 0-based page index for vision fallback (default 0).
# PDF_VISION_FALLBACK_PAGE=0

# Structured AI parse concurrency (default 10 — Gemini 2.5 has higher quota than legacy Nemotron).
# NEMOTRON_STRUCTURED_CONCURRENCY=10

# Cloud Vision API — OCR for PDFs and inline images (separate GCP account/key).
# DOCUMENT_TEXT_DETECTION: purpose-built for dense automotive service documents.
# Used in priority chain: Document AI → Cloud Vision → pdfjs → Gemini vision.
# CLOUD_VISION_API_KEY=your-vision-api-key-here

# Document AI — high-quality PDF parsing (tables, lists, headers natively understood).
# Uses Gen AI App Builder credits. Set ENABLE_DOCUMENT_AI=true to activate.
# Setup: create a Layout Parser processor at console.cloud.google.com/ai/document-ai/processors
# ENABLE_DOCUMENT_AI=true
# DOCUMENT_AI_PROCESSOR=abc123def456  (processor ID from console, or full resource name)
# DOCUMENT_AI_LOCATION=us

# Vertex AI RAG Engine — managed semantic corpus for article retrieval.
# Uses Gen AI App Builder credits. Set VERTEX_RAG_CORPUS after creating the corpus.
# Setup:
#   gcloud ai rag-corpora create \
#     --display-name="vehapi-motor-articles" \
#     --embedding-model-config-publisher-model="publishers/google/models/text-embedding-004" \
#     --region=us-central1
# Then copy the corpus resource name (or just the numeric ID) here:
# VERTEX_RAG_CORPUS=1234567890123456789

# Record PDF article bodies in `media_asset` (sha256, mime) during worker parse. Default on.
# ENABLE_MEDIA_ASSET_PDF=true

# OCR inline <img> tags in HTML article bodies before AI parse (DTC/TSB image-heavy pages).
# Uses Nemotron vision (same as PDF). Capped to HTML_IMAGE_OCR_MAX images per article (default 10).
# ENABLE_HTML_IMAGE_OCR=true
# HTML_IMAGE_OCR_MAX=10

# Cloud SQL (PostgreSQL) — used for all DB operations.
# Cloud Run: set CLOUD_SQL_CONNECTION_NAME (e.g. "vehapi-torque:us-central1:vehapi")
#   + DB_NAME, DB_USER, DB_PASSWORD via Secret Manager or --set-env-vars.
# Local dev: set DATABASE_URL to a full Postgres URI.
# DATABASE_URL=postgres://user:pass@localhost:5432/vehapi
# CLOUD_SQL_CONNECTION_NAME=vehapi-torque:us-central1:vehapi
# DB_NAME=vehapi
# DB_USER=vehapi
# DB_PASSWORD=your_db_password

# Firebase Auth — server-side JWT verification (replaces SUPABASE_JWT_SECRET).
# On Cloud Run, Application Default Credentials are used automatically.
# For local dev: set GOOGLE_APPLICATION_CREDENTIALS or run `gcloud auth application-default login`.
# FIREBASE_PROJECT_ID=vehapi-torque  (defaults to GOOGLE_CLOUD_PROJECT)

# `articles` upserts: default includes all catalog columns. Set false to use minimal subset.
# ARTICLES_UPSERT_EXTENDED=true

# Concurrency for structured Nemotron calls (parse, tutorials, common-issues). Default 3 — reduces 429s.
# NEMOTRON_STRUCTURED_CONCURRENCY=3

# Article content GET rate limit (per IP, or per user when Bearer JWT verifies with SUPABASE_JWT_SECRET). Behind Vercel use trust proxy. Verify script uses x-vehapi-verify — not limited.
# ARTICLE_RATE_LIMIT_WINDOW_MS=60000
# ARTICLE_RATE_LIMIT_MAX=120

# Minimum Supabase `articles` rows + `vehicles.is_normalized` before proxy serves catalog from DB (default 10). Lower only if OEM catalogs are tiny.
# ARTICLE_CATALOG_MIN_ROWS=10

# L2 RAG — optional; requires Cloud SQL pgvector with vector(768).
# Worker parse must run with ENABLE_L2_EMBEDDINGS so rows land in content_chunk.
# Torque UI returns L2_NO_CHUNKS when no indexed chunks (distinct from L2_DISABLED / misconfig).
# ENABLE_L2_EMBEDDINGS=true
# EMBEDDING_MODEL=text-embedding-004
# L2_EMBEDDING_DIMS=768
# L2_CHUNK_MAX_CHARS=1800
# L2_CHUNK_OVERLAP=120
# L2_EMBED_BATCH_SIZE=16

# Stripe (Payments / Credits)
STRIPE_SANDBOX_SKEY=your_stripe_test_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
