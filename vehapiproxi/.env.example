# Environment Configuration
# Copy this file to .env and fill in your credentials

LIBRARY_BARCODE=247777625491...
EBSCO_USER=pl7321r
EBSCO_PASSWORD=PL?7321R
MOTOR_API_BASE=https://sites.motor.com/m1
PROXY_PORT=3001
NODE_ENV=production

# Set to 'development' to see the browser during authentication
# NODE_ENV=development

# NVIDIA Nemotron (all AI: parsing, rewrite, tutorials, common-issues)
# Get key from https://build.nvidia.com/ — API key for NVIDIA NIM / integrate.api.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here

# Supabase (For Background DB Caching)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Direct Postgres for schema migrations (run-migrate-schema.js). Use one of:
# - SUPABASE_DB_URL = full URI from Dashboard → Database → Connection string (use "Direct" to avoid pooler errors)
# - SUPABASE_DB_PASSWORD = database password (script builds URL from SUPABASE_URL + this)
# SUPABASE_DB_PASSWORD=your_database_password

# Stripe (Payments / Credits)
STRIPE_SANDBOX_SKEY=your_stripe_test_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
