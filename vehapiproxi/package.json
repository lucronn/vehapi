{
    "name": "motorapi-auth-proxy",
    "version": "1.0.0",
    "description": "Authentication proxy for Motor API with automated login flow",
    "main": "src/function.js",
    "engines": {
        "node": "22"
    },
    "type": "module",
    "scripts": {
        "start": "node src/index.js",
        "dev": "node --watch src/index.js",
        "debug": "NODE_ENV=development node src/index.js",
        "verify:release-target": "node scripts/verify-release-target.js",
        "verify:golden-vehicles": "node scripts/verify-golden-vehicles.js",
        "test:normalization": "node scripts/test-normalization-one-per-category.js",
        "check:nemotron": "node scripts/check-nemotron.mjs",
        "verify:evidence-links": "node scripts/verify-evidence-links-one-article.js",
        "verify:evidence-links:local": "node scripts/verify-evidence-links-one-article.js --local",
        "test:article-rate-limit": "node scripts/test-article-rate-limit.js",
        "sync:catalog": "node scripts/sync-catalog-vehicle.js",
        "seed:ymme": "node scripts/seed-ymme-cloudsql.mjs",
        "verify:ingest-golden": "node scripts/verify-ingest-golden.js",
        "ingest:dashboard": "node scripts/ingest-progress-dashboard.mjs",
        "worker:ingest-full": "node scripts/worker-ingest-vehicles-full.js",
        "worker:ingest-surface": "node scripts/worker-ingest-vehicles-full.js --metadata-only",
        "worker:ingest-loop": "node scripts/worker-ingest-vehicles-full.js --continuous --resume --metadata-only"
    },
    "keywords": [
        "proxy",
        "motor-api",
        "authentication"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@google-cloud/documentai": "^9.6.1",
        "@google/genai": "latest",
        "canvas": "^3.1.0",
        "cheerio": "^1.2.0",
        "cookie": "^0.6.0",
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.5.1",
        "firebase-admin": "^13.9.0",
        "google-auth-library": "^9.0.0",
        "http-proxy-middleware": "^2.0.6",
        "jsonwebtoken": "^9.0.2",
        "node-fetch": "^3.3.2",
        "openai": "^6.29.0",
        "p-limit": "^7.3.0",
        "pdfjs-dist": "^4.10.38",
        "pg": "^8.18.0",
        "socks": "^2.8.9",
        "socks-proxy-agent": "^10.0.0",
        "stripe": "^20.3.1",
        "swagger-ui-express": "^5.0.1",
        "turndown": "^7.2.2",
        "winston": "^3.11.0",
        "yamljs": "^0.3.0",
        "zod": "^4.3.6"
    }
}
